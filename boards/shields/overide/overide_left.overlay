#include "overide.dtsi"

&kscan0 {
    col-gpios
        = <&gpio0 3  GPIO_ACTIVE_HIGH> // D1 is P0.03
        , <&gpio0 28 GPIO_ACTIVE_HIGH> // D2 is P0.28
        , <&gpio0 29 GPIO_ACTIVE_HIGH> // D3 is P0.29
        , <&gpio0 4  GPIO_ACTIVE_HIGH> // D4 is P0.04
        , <&gpio0 5  GPIO_ACTIVE_HIGH> // D5 is P0.05
        ;
};