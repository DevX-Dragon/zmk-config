#include "overide.dtsi"

&kscan0 {
    col-gpios
        = <&gpio0 3  GPIO_ACTIVE_HIGH> // COL0 - D1
        , <&gpio0 28 GPIO_ACTIVE_HIGH> // COL1 - D2
        , <&gpio0 29 GPIO_ACTIVE_HIGH> // COL2 - D3
        , <&gpio0 4  GPIO_ACTIVE_HIGH> // COL3 - D4
        , <&gpio0 5  GPIO_ACTIVE_HIGH> // COL4 - D5
        ;
};